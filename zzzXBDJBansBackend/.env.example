# Database
DATABASE_URL=postgres://zzzXBDJBans:replace_me@127.0.0.1:5432/zzzXBDJBans

# Optional
REDIS_URL=redis://127.0.0.1:6379/

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUST_LOG=info

# Security
JWT_SECRET=replace_with_a_long_random_secret
PLUGIN_API_TOKEN=replace_with_a_long_random_plugin_token

# Steam / verification
STEAM_API_KEY=replace_me
PLUGIN_REQUIRED_RATING=3.0
PLUGIN_REQUIRED_LEVEL=1

# Bootstrap admin
BOOTSTRAP_ADMIN_USERNAME=admin
